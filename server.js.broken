// Required middleware
app.use(express.json());
app.use(express.static('public'));

// Payment route
app.post("/api/payment-request", (req, res) => {
  const { student_name, student_class, parent_phone, amount } = req.body;
  const reference = "MAN-" + Date.now();
  
  if (!student_name || !amount) {
    return res.status(400).json({ error: "Missing fields" });
  }
  
  console.log("New payment request: " + reference + " - " + student_name + " - " + amount + " UGX");
  res.json({ success: true, reference });
});

// Start server
const PORT = 5000;
const server = app.listen(PORT, "0.0.0.0", (err) => {
  if (err) {
    console.error("LISTEN FAILED:", err);
    process.exit(1);
  }
  console.log(`? Server running on http://localhost:${PORT}`);
  console.log(`? Open: http://127.0.0.1:${PORT}/checkout.html`);
});

// Keep process alive
process.stdin.resume();
